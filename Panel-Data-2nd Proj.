# ============================================================
# تحليل بيانات Panel Data
# نموذج الدراسة:
# GOPit = β0 + β1(CCCit) + β2(WCTit) + β3(Fsizeit) + εit
# ============================================================


# ============================================================
# 1. تحميل الحزم المطلوبة
# ============================================================

packages <- c("readxl", "plm", "lmtest", "sandwich", "car", "dplyr", "psych")

installed_packages <- rownames(installed.packages())

for (p in packages) {
  if (!(p %in% installed_packages)) {
    install.packages(p)
  }
  library(p, character.only = TRUE)
}


# ============================================================
# 2. استيراد البيانات
# ============================================================

data <- read_excel("proj.2.xlsx")


# ============================================================
# 3. فحص أولي للبيانات
# ============================================================

# عرض أسماء الأعمدة
names(data)

# عرض أول الصفوف
head(data)

# هيكل البيانات
str(data)

# ملخص عام
summary(data)


# ============================================================
# 4. التأكد من أسماء الأعمدة المطلوبة
# ============================================================

required_cols <- c("Firm", "year", "GOP", "CCC", "WCT", "Fsize")

missing_cols <- setdiff(required_cols, names(data))

if (length(missing_cols) > 0) {
  stop(paste("الأعمدة التالية غير موجودة في الملف:", 
             paste(missing_cols, collapse = ", ")))
}


# ============================================================
# 5. تنظيف وتجهيز البيانات
# ============================================================

data <- data %>%
  mutate(
    Firm  = as.factor(Firm),
    year  = as.numeric(year),
    GOP   = as.numeric(GOP),
    CCC   = as.numeric(CCC),
    WCT   = as.numeric(WCT),
    Fsize = as.numeric(Fsize)
  )

# حذف الصفوف التي تحتوي على قيم مفقودة في متغيرات الدراسة
data <- na.omit(data)

# التأكد من عدم وجود تكرار لنفس الشركة في نفس السنة
duplicated_rows <- data %>%
  group_by(Firm, year) %>%
  filter(n() > 1)

duplicated_rows

# إذا ظهرت لك نتائج هنا، فهذا يعني وجود تكرار يجب مراجعته قبل التحليل.


# ============================================================
# 6. تعريف بيانات البانل
# ============================================================

pdata <- pdata.frame(data, index = c("Firm", "year"))

# فحص هيكل بيانات البانل
pdim(pdata)

# هل البيانات متوازنة؟
is.pbalanced(pdata)


# ============================================================
# 7. الإحصاءات الوصفية
# ============================================================

describe(data[, c("GOP", "CCC", "WCT", "Fsize")])


# ============================================================
# 8. مصفوفة الارتباط
# ============================================================

cor_matrix <- cor(data[, c("GOP", "CCC", "WCT", "Fsize")], 
                  use = "complete.obs")

cor_matrix


# ============================================================
# 9. اختبار التعدد الخطي VIF
# ============================================================

# يتم حساب VIF من نموذج lm عادي، وليس من plm مباشرة
vif_model <- lm(GOP ~ CCC + WCT + Fsize, data = data)

summary(vif_model)

vif(vif_model)


# ============================================================
# 10. نموذج Pooled OLS
# ============================================================

pooled_model <- plm(GOP ~ CCC + WCT + Fsize,
                    data = pdata,
                    model = "pooling")

summary(pooled_model)


# ============================================================
# 11. نموذج التأثيرات الثابتة Fixed Effects
# ============================================================

fixed_model <- plm(GOP ~ CCC + WCT + Fsize,
                   data = pdata,
                   model = "within")

summary(fixed_model)


# ============================================================
# 12. نموذج التأثيرات العشوائية Random Effects
# ============================================================

random_model <- plm(GOP ~ CCC + WCT + Fsize,
                    data = pdata,
                    model = "random")

summary(random_model)


# ============================================================
# 13. اختبارات المفاضلة بين النماذج
# ============================================================

# ------------------------------------------------------------
# 13.1 اختبار المفاضلة بين Pooled OLS و Fixed Effects
# H0: نموذج Pooled هو الأنسب
# H1: نموذج Fixed Effects هو الأنسب
# ------------------------------------------------------------

pFtest(fixed_model, pooled_model)


# ------------------------------------------------------------
# 13.2 اختبار المفاضلة بين Pooled OLS و Random Effects
# Breusch-Pagan LM Test
# H0: نموذج Pooled هو الأنسب
# H1: نموذج Random Effects هو الأنسب
# ------------------------------------------------------------

plmtest(pooled_model, type = "bp")


# ------------------------------------------------------------
# 13.3 اختبار Hausman للمفاضلة بين Fixed و Random
# H0: نموذج Random Effects هو الأنسب
# H1: نموذج Fixed Effects هو الأنسب
# ------------------------------------------------------------

phtest(fixed_model, random_model)


# ============================================================
# 14. اختبارات التشخيص
# ============================================================

# ------------------------------------------------------------
# 14.1 اختبار الارتباط الذاتي Serial Correlation
# H0: لا توجد مشكلة ارتباط ذاتي
# ------------------------------------------------------------

pbgtest(fixed_model)
pbgtest(random_model)


# ------------------------------------------------------------
# 14.2 اختبار عدم تجانس التباين Heteroskedasticity
# H0: لا توجد مشكلة عدم تجانس تباين
# ------------------------------------------------------------

bptest(pooled_model)
bptest(fixed_model)
bptest(random_model)


# ------------------------------------------------------------
# 14.3 اختبار الاعتماد المقطعي Cross-sectional Dependence
# H0: لا يوجد اعتماد مقطعي بين الشركات
# ------------------------------------------------------------

pcdtest(fixed_model, test = "cd")
pcdtest(random_model, test = "cd")


# ============================================================
# 15. الأخطاء المعيارية القوية Robust Standard Errors
# ============================================================

# ------------------------------------------------------------
# 15.1 Pooled OLS مع Robust SE
# ------------------------------------------------------------

coeftest(pooled_model, 
         vcov = vcovHC(pooled_model, type = "HC1"))


# ------------------------------------------------------------
# 15.2 Fixed Effects مع Robust SE
# ------------------------------------------------------------

coeftest(fixed_model, 
         vcov = vcovHC(fixed_model, type = "HC1"))


# ------------------------------------------------------------
# 15.3 Random Effects مع Robust SE
# ------------------------------------------------------------

coeftest(random_model, 
         vcov = vcovHC(random_model, type = "HC1"))


# ============================================================
# 16. أخطاء معيارية قوية حسب الشركة Clustered by Firm
# ============================================================

# هذا الخيار مفيد جدًا في بيانات البانل

coeftest(fixed_model,
         vcov = vcovHC(fixed_model, type = "HC1", cluster = "group"))

coeftest(random_model,
         vcov = vcovHC(random_model, type = "HC1", cluster = "group"))


# ============================================================
# 17. حفظ النتائج الأساسية في كائنات
# ============================================================

summary_pooled <- summary(pooled_model)
summary_fixed  <- summary(fixed_model)
summary_random <- summary(random_model)

summary_pooled
summary_fixed
summary_random


# ============================================================
# 18. نهاية السكربت
# ============================================================
