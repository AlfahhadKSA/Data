my_winsorize <- function(x, lower = 0.01, upper = 0.99) {
  limits <- quantile(x, probs = c(lower, upper), na.rm = TRUE)
  x[x < limits[1]] <- limits[1]
  x[x > limits[2]] <- limits[2]
  return(x)
}

