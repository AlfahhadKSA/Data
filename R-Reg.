# 7) تحليل التباين (Overall / Between / Within)
# ==============================================================================

calc_variation <- function(var_name, df) {
  df_clean <- df %>% filter(!is.na(.data[[var_name]]))
  
  overall_sd <- sd(df_clean[[var_name]], na.rm = TRUE)
  
  firm_means <- df_clean %>%
    group_by(firm) %>%
    summarise(f_mean = mean(.data[[var_name]], na.rm = TRUE), .groups = "drop")
  
  sd_between <- sd(firm_means$f_mean, na.rm = TRUE)
  
  df_clean <- df_clean %>%
    left_join(firm_means, by = "firm") %>%
    mutate(demeaned = .data[[var_name]] - f_mean + mean(.data[[var_name]], na.rm = TRUE))
  
  sd_within <- sd(df_clean$demeaned, na.rm = TRUE)
  
  changes <- df_clean %>%
    group_by(firm) %>%
    summarise(is_changed = min(.data[[var_name]], na.rm = TRUE) != max(.data[[var_name]], na.rm = TRUE),
              .groups = "drop")
  
  data.frame(
    Variable = var_name,
    SD_Overall = round(overall_sd, 3),
    SD_Between = round(sd_between, 3),
    SD_Within  = round(sd_within, 3),
    Firms_Changed   = sum(changes$is_changed, na.rm = TRUE),
    Firms_Unchanged = sum(!changes$is_changed, na.rm = TRUE)
  )
}

variation_table <- bind_rows(lapply(vars_to_analyze, calc_variation, df = data3))

