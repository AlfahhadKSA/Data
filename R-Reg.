# ==============================================================================

f_test       <- pFtest(fe, pool)
lm_test      <- plmtest(pool, type = "bp")
hausman_test <- phtest(fe, re)
bp_test      <- bptest(pool, studentize = FALSE)
bg_test      <- pbgtest(fe)

decision_text <- function(test_name, p_value) {
  if (test_name == "F-Test") {
    if (p_value < 0.05) {
      return("رفض H0 وتفضيل نموذج التأثيرات الثابتة")
    } else {
      return("عدم رفض H0 وتفضيل النموذج التجميعي")
    }
  }
  
  if (test_name == "Breusch-Pagan LM") {
    if (p_value < 0.05) {
      return("رفض H0 وتفضيل نموذج التأثيرات العشوائية")
    } else {
      return("عدم رفض H0 وتفضيل النموذج التجميعي")
    }
  }
  
  if (test_name == "Hausman Test") {
    if (p_value < 0.05) {
      return("رفض H0 وتفضيل نموذج التأثيرات الثابتة")
    } else {
      return("عدم رفض H0 وتفضيل نموذج التأثيرات العشوائية")
    }
  }
  
  if (test_name == "Breusch-Pagan") {
    if (p_value < 0.05) {
      return("رفض H0 وتوجد مشكلة عدم تجانس تباين")
    } else {
      return("عدم رفض H0 ولا توجد مشكلة معنوية في عدم تجانس التباين")
    }
  }
  
  if (test_name == "Breusch-Godfrey") {
    if (p_value < 0.05) {
      return("رفض H0 وتوجد مشكلة ارتباط ذاتي")
    } else {
      return("عدم رفض H0 ولا توجد مشكلة ارتباط ذاتي")
    }
  }
  
  return(NA)
}

diagnostics_table <- data.frame(
