# 15) جدول معاملات النموذج النهائي
# ==============================================================================

coef_table <- data.frame(
  Variable    = rownames(robust_results),
  Coefficient = robust_results[, 1],
  Std_Error   = robust_results[, 2],
  Statistic   = robust_results[, 3],
  P_value     = robust_results[, 4],
  stringsAsFactors = FALSE
)

coef_table <- coef_table %>%
  mutate(
    Significance = case_when(
      P_value < 0.01 ~ "***",
      P_value < 0.05 ~ "**",
      P_value < 0.10 ~ "*",
      TRUE ~ ""
    ),
    Decision = case_when(
      Variable %in% c("ACSIZE", "ACIND", "ACMEET", "ACEXP", "ACNEW", "LOGSIZE") & P_value < 0.05 & Coefficient > 0 ~ "يوجد أثر موجب ذو دلالة",
      Variable %in% c("ACSIZE", "ACIND", "ACMEET", "ACEXP", "ACNEW", "LOGSIZE") & P_value < 0.05 & Coefficient < 0 ~ "يوجد أثر عكسي ذو دلالة",
      Variable %in% c("ACSIZE", "ACIND", "ACMEET", "ACEXP", "ACNEW", "LOGSIZE") & P_value >= 0.05 ~ "لا يوجد أثر ذو دلالة",
      TRUE ~ "-"
    )
  )

coef_table$Coefficient <- round(coef_table$Coefficient, 4)
coef_table$Std_Error   <- round(coef_table$Std_Error, 4)
coef_table$Statistic   <- round(coef_table$Statistic, 4)
